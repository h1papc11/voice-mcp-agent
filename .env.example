# Voicebox environment configuration (development)
# Copy to .env and adjust values as needed.

# --- Backend ---
LOG_LEVEL=info
# VOICEBOX_HOST=127.0.0.1
# VOICEBOX_PORT=17493
# VOICEBOX_CORS_ORIGINS=http://localhost:5173

# --- Optional cache persistence (web deployments) ---
VOICEBOX_REDIS_ENABLED=false
# VOICEBOX_REDIS_URL=redis://127.0.0.1:6379/0
# VOICEBOX_REDIS_HOST=127.0.0.1
# VOICEBOX_REDIS_PORT=6379
# VOICEBOX_REDIS_KEY_PREFIX=voicebox:

# --- Logging ---
# VOICEBOX_LOG_LEVEL=debug

# --- External services (optional) ---
# HF_TOKEN=
# HELIUS_API_KEY=
